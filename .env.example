# Sentinel environment variables
# Copy to `.env` and fill in the values you have. Missing values fall back to defaults in config.py.

# --- Storage ----------------------------------------------------------------
# Where DuckDB lives. Relative paths are resolved from the repo root.
SENTINEL_DB_PATH=data/sentinel.duckdb

# --- Reddit -----------------------------------------------------------------
# Create an app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=sentinel/0.1 by <your-reddit-username>

# --- Twitter / X ------------------------------------------------------------
# Bearer token from https://developer.x.com. Required for `sentinel ingest twitter`.
TWITTER_BEARER_TOKEN=

# --- Crypto (CCXT) ----------------------------------------------------------
# No credentials required for public OHLCV endpoints on Binance / Coinbase /
# Kraken etc. `sentinel ingest crypto BTC-USD` works out of the box with
# `pip install -e '.[crypto]'`.

# --- Logging ----------------------------------------------------------------
# DEBUG | INFO | WARNING | ERROR
SENTINEL_LOG_LEVEL=INFO
