# Sentinel environment variables
# Copy to `.env` and fill in the values you have. Missing values fall back to defaults in config.py.

# --- Storage ----------------------------------------------------------------
# Where DuckDB lives. Relative paths are resolved from the repo root.
SENTINEL_DB_PATH=data/sentinel.duckdb

# --- Reddit (roadmap) -------------------------------------------------------
# Create an app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=sentinel/0.1 by <your-reddit-username>

# --- Twitter / X (roadmap) --------------------------------------------------
# Bearer token from https://developer.x.com
TWITTER_BEARER_TOKEN=

# --- Logging ----------------------------------------------------------------
# DEBUG | INFO | WARNING | ERROR
SENTINEL_LOG_LEVEL=INFO
